{
  "name": "folderandgraphs-plus",
  "version": "1.0.2",
  "description": "Apply native Obsidian graph group colours to Folder2Graph folder nodes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "folder2graph",
    "graph"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.0"
  }
}
